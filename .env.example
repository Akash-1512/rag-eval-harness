# ═══════════════════════════════════════════════════════════════
# LOCAL DEMO STACK — fill these to run free
# All defaults below run the FULL system at zero cost
# ═══════════════════════════════════════════════════════════════

# Groq — free tier, no card required
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model for RAG generation
# Alternatives: llama-3.1-8b-instant (faster), mixtral-8x7b-32768 (longer context)
GROQ_MODEL_NAME=llama-3.3-70b-versatile

# LangSmith — free tier tracing (optional but recommended)
# Get key at: https://smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_key_here
LANGCHAIN_TRACING_V2=false

# Embeddings — sentence-transformers runs fully local, zero API calls
# Model downloads automatically on first run (~90MB)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# MLflow — local server, zero cost
# Run in separate terminal: mlflow ui --port 5000
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT_NAME=rag-eval-harness

# Evaluation config
RAGAS_RUN_CONFIG_TIMEOUT=180
DEEPEVAL_CONFIDENCE_THRESHOLD=0.5

# Chunking defaults (can override per run via API or CLI)
CHUNK_SIZE=2048
CHUNK_OVERLAP=256
CHUNKING_STRATEGY=recursive

# Demo mode flag — forces all providers to free-tier alternatives
# Set to false only when all [PRODUCTION] vars below are filled
DEMO_MODE=true

# ═══════════════════════════════════════════════════════════════
# [PRODUCTION] Azure Stack — fill for production
# Leave blank for local demo — not needed locally
# Set DEMO_MODE=false when switching to this stack
# ═══════════════════════════════════════════════════════════════

# Azure OpenAI — LLM + embeddings
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure AI Search — vector store (replaces FAISS)
# Required for: hybrid BM25+dense retrieval, 20,000+ docs
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX_NAME=rag-eval-harness-prod

# Azure ML — MLflow tracking (replaces local server)
# Get URI from: Azure ML workspace -> MLflow tracking URI
AZURE_ML_TRACKING_URI=
