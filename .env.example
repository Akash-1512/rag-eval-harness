# ════════════════════════════════════════════════════════════════
# DEMO STACK (zero budget) — fill these to run locally
# ════════════════════════════════════════════════════════════════

# Groq — free tier, no card required
# Get key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Groq model — llama-3.1-70b-versatile is the recommended free model
# Alternatives: llama-3.1-8b-instant (faster), mixtral-8x7b-32768 (longer context)
GROQ_MODEL_NAME=llama-3.1-70b-versatile

# Embeddings — sentence-transformers runs fully local, zero API calls
# Model downloads automatically on first run (~90MB)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# MLflow — local server, zero cost
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT_NAME=rag-eval-harness

# Evaluation config
RAGAS_RUN_CONFIG_TIMEOUT=180
DEEPEVAL_CONFIDENCE_THRESHOLD=0.7

# Chunking defaults (can override per run)
CHUNK_SIZE=512
CHUNK_OVERLAP=64
CHUNKING_STRATEGY=recursive

# ════════════════════════════════════════════════════════════════
# PROD STACK (paid) — commented out, uncomment to switch
# ════════════════════════════════════════════════════════════════

# Azure OpenAI
# AZURE_OPENAI_API_KEY=your_azure_openai_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Azure AI Search (20,000+ docs)
# AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
# AZURE_SEARCH_KEY=your_search_admin_key
# AZURE_SEARCH_INDEX_NAME=rag-eval-harness-prod

# Azure ML (prod MLflow tracking)
# AZUREML_TRACKING_URI=azureml://your-workspace-url